# Runtime
ENVIRONMENT=dev
LOG_LEVEL=INFO
API_TITLE=Intelligent Search Agent
CORS_ORIGINS=*

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=intelligent_search_agent
DB_USER=postgres
DB_PASSWORD=postgres
# DB_SSLMODE=require

# Chat model. This project is configured for direct OpenAI by default.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
VISION_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Retrieval tuning
RAG_TOP_K=10
RAG_CANDIDATE_K=200
RAG_MIN_SIMILARITY=0.30
RAG_HYBRID_ALPHA=0.70
AGENT_REQUEST_LIMIT=8
LLM_RERANK_ENABLED=true
LLM_RERANK_TOP_K=12
PERSIST_CHAT_SESSIONS=true

# Admin/security
ENABLE_ADMIN_API=true
# Set this before deploying outside local/dev. Admin endpoints require X-Admin-Key when set.
ADMIN_API_KEY=
ALLOWED_SOURCE_URL_HOSTS=commons.wikimedia.org,upload.wikimedia.org,journalbelgianhistory.be,www.journalbelgianhistory.be

# Asset storage
# local: files live under ASSET_ROOT
# network: file_path/storage_uri points at a mounted drive or UNC path available to the API
# http: storage_uri/source_url is an HTTP URL served by another internal service
# s3/minio: store an S3-compatible object key/URI and expose source_url when needed
ASSET_STORAGE_BACKEND=local
ASSET_ROOT=storage/assets
